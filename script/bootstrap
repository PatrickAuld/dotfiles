#!/usr/bin/env bash
#
# bootstrap installs things.

set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)

GIT_AUTHOR_NAME_ARG=""
GIT_AUTHOR_EMAIL_ARG=""
CONFLICT_POLICY_ARG=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --git-name)
      GIT_AUTHOR_NAME_ARG=${2:-}
      shift 2
      ;;
    --git-email)
      GIT_AUTHOR_EMAIL_ARG=${2:-}
      shift 2
      ;;
    --conflict)
      CONFLICT_POLICY_ARG=${2:-}
      shift 2
      ;;
    --help|-h)
      cat <<'EOF'
Usage: script/bootstrap [--git-name NAME] [--git-email EMAIL] [--conflict POLICY]

Options:
  --git-name NAME       Git author/user name for gitconfig.local
  --git-email EMAIL     Git author email for gitconfig.local
  --conflict POLICY     Conflict policy for existing files: skip|overwrite|backup

For unattended bootstrap, provide both --git-name and --git-email
(or equivalent env vars) so gitconfig.local can be generated without prompts.
In non-interactive mode, file conflicts default to: skip.
EOF
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 1
      ;;
  esac
done

echo ''

info () {
  printf "\r  [ \033[00;34m..\033[0m ] $1\n"
}

user () {
  printf "\r  [ \033[0;33m??\033[0m ] $1\n"
}

success () {
  printf "\r\033[2K  [ \033[00;32mOK\033[0m ] $1\n"
}

fail () {
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] $1\n"
  echo ''
  exit
}

setup_gitconfig () {
  if ! [ -f git/gitconfig.local.symlink ]
  then
    info 'setup gitconfig'

    git_credential='cache'
    if [ "$(uname -s)" == "Darwin" ]
    then
      git_credential='osxkeychain'
    fi

    git_authorname=${GIT_AUTHOR_NAME_ARG:-${DOTFILES_GIT_AUTHORNAME:-${GIT_AUTHOR_NAME:-""}}}
    git_authoremail=${GIT_AUTHOR_EMAIL_ARG:-${DOTFILES_GIT_AUTHOREMAIL:-${GIT_AUTHOR_EMAIL:-""}}}

    # Non-interactive sessions (CI, scripts) must not prompt; require explicit identity.
    if [ ! -t 0 ] || [ ! -t 1 ]; then
      if [ -z "$git_authorname" ] || [ -z "$git_authoremail" ]; then
        fail "non-interactive bootstrap requires --git-name and --git-email (or DOTFILES_GIT_AUTHORNAME / DOTFILES_GIT_AUTHOREMAIL)"
      fi
    else
      if [ -z "$git_authorname" ]; then
        user ' - What is your github author name?'
        read -r -e git_authorname
      fi
      if [ -z "$git_authoremail" ]; then
        user ' - What is your github author email?'
        read -r -e git_authoremail
      fi
    fi

    sed -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" git/gitconfig.local.symlink.example > git/gitconfig.local.symlink

    success 'gitconfig'
  fi
}


link_file () {
  local src=$1 dst=$2

  local overwrite= backup= skip=
  local action=

  if [ -f "$dst" -o -d "$dst" -o -L "$dst" ]
  then

    if [ "$overwrite_all" == "false" ] && [ "$backup_all" == "false" ] && [ "$skip_all" == "false" ]
    then

      local currentSrc="$(readlink "$dst" 2>/dev/null || true)"

      if [ "$currentSrc" == "$src" ]
      then

        skip=true;

      else

        if [ ! -t 0 ] || [ ! -t 1 ]; then
          skip_all=true
        else
          user "File already exists: $dst ($(basename "$src")), what do you want to do?\n\
        [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
          read -r -n 1 action

          case "$action" in
            o )
              overwrite=true;;
            O )
              overwrite_all=true;;
            b )
              backup=true;;
            B )
              backup_all=true;;
            s )
              skip=true;;
            S )
              skip_all=true;;
            * )
              ;;
          esac
        fi

      fi

    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}

    if [ "$overwrite" == "true" ]
    then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" == "true" ]
    then
      mv "$dst" "${dst}.backup"
      success "moved $dst to ${dst}.backup"
    fi

    if [ "$skip" == "true" ]
    then
      success "skipped $src"
    fi
  fi

  if [ "$skip" != "true" ]  # "false" or empty
  then
    ln -s "$1" "$2"
    
    # Validate the symlink was created correctly
    if [ -L "$2" ] && [ "$(readlink "$2")" = "$1" ]; then
      # Set appropriate permissions (readable by owner)
      chmod 644 "$2" 2>/dev/null || true
      success "linked $1 to $2"
    else
      fail "failed to create symlink from $1 to $2"
    fi
  fi
}

install_dotfiles () {
  info 'installing dotfiles'

  local overwrite_all=false backup_all=false skip_all=false

  case "$CONFLICT_POLICY_ARG" in
    "")
      if [ ! -t 0 ] || [ ! -t 1 ]; then
        skip_all=true
      fi
      ;;
    skip)
      skip_all=true
      ;;
    overwrite)
      overwrite_all=true
      ;;
    backup)
      backup_all=true
      ;;
    *)
      fail "invalid --conflict value: $CONFLICT_POLICY_ARG (expected: skip, overwrite, or backup)"
      ;;
  esac

  for src in $(find -H "$DOTFILES_ROOT" -maxdepth 2 -name '*.symlink' -not -path '*.git*')
  do
    dst="$HOME/.$(basename "${src%.*}")"
    link_file "$src" "$dst"
  done
}

setup_gitconfig
install_dotfiles

# OS-specific setup
if [ "$(uname -s)" == "Darwin" ]
then
  info "setting macOS defaults"
  if macos/set-defaults.sh | while read -r data; do info "$data"; done
  then
    success "macOS defaults set"
  else
    fail "error setting macOS defaults"
  fi
fi

info "installing dependencies"
if script/install | while read -r data; do info "$data"; done
then
  success "dependencies installed"
else
  fail "error installing dependencies"
fi

echo ''
echo '  All installed!'
